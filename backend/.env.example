APP_NAME=24小时AI增长资产引擎
APP_ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-secret
ACCESS_TOKEN_EXPIRE_SECONDS=7200

# 用户要求的 MySQL 数据库名：AIdrivenGrowthAssetEngine
DATABASE_NAME=AIdrivenGrowthAssetEngine
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/AIdrivenGrowthAssetEngine?charset=utf8mb4

REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
ENABLE_CELERY_TASKS=false
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
STORAGE_ROOT=../storage

# 抓取配置。没有搜索 API 时会抓取 FETCH_SEED_URLS 中的公开页面。
FETCH_TIMEOUT_SECONDS=20
FETCH_MAX_CONTENT_CHARS=12000
FETCH_SEED_URLS=https://www.technologyreview.com/topic/artificial-intelligence/,https://openai.com/news/

# LLM 默认配置。兼容 OpenAI 风格接口，不要把真实 Key 提交到代码仓库。
LLM_MODEL_PROVIDER=openai_compatible
LLM_MODEL_BASE_URL=https://api.example.com/v1
LLM_MODEL_API_KEY=
LLM_MODEL_NAME=
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_ENABLE_REAL_CALLS=false

# FFmpeg 配置。Windows 可填 ffmpeg.exe 或 ffmpeg.cmd 的绝对路径。
FFMPEG_BIN=ffmpeg
ENABLE_REAL_FFMPEG=false

DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin123456
DEFAULT_ADMIN_DISPLAY_NAME=管理员
