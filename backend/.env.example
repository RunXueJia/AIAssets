APP_NAME=Hours24 Backend
ENVIRONMENT=local

# MySQL async runtime URL used by FastAPI / SQLAlchemy.
# Create the database before starting the backend.
DATABASE_URL=mysql+asyncmy://hours24:hours24_password@127.0.0.1:3306/hours24?charset=utf8mb4
TEST_DATABASE_URL=mysql+asyncmy://hours24:hours24_password@127.0.0.1:3306/hours24_test?charset=utf8mb4

REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET_KEY=replace-with-a-random-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_MINUTES=10080

ENCRYPTION_KEY=replace-with-a-random-encryption-secret
CORS_ORIGINS=["http://127.0.0.1:5173","http://127.0.0.1:5174"]

OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_BUCKET=hours24
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
